{
  "name": "lovematch/app-tests",
  "description": "LoveMatch automated tests",
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "guzzlehttp/guzzle": "^7.8"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit",
    "test:frontend": "@php vendor/bin/phpunit tests/Frontend tests/Smoke",
    "test:api": "@php vendor/bin/phpunit tests/Feature"
  }
}
