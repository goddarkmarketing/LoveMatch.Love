 *        GRANT ALL PRIVILEGES ON lovematch_love.* TO 'lovematch'@'localhost';
 *        FLUSH PRIVILEGES;
 *   3. Import db/schema.sql (and seed) as that user or as root from mysql CLI.
 *   4. Put username/password below and save as database.local.php
 */

